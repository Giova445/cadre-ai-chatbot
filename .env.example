# =============================================================================
# Cadre AI Support Chatbot — environment
# Copy to .env.local and fill in. NEVER commit real keys (.env.local is ignored).
#
# With NO keys the app runs fully offline: a deterministic lexical embedder backs
# retrieval and the chat route returns grounded-stub / escalation text. Add keys
# for real embeddings + a streamed LLM answer.
#
# ONLY the variables below are read by the code. The embedding model and its
# dimensions are FIXED in lib/config.ts (text-embedding-3-small, 512) — there is
# no EMBEDDINGS_MODEL / EMBEDDINGS_DIMENSIONS env var.
# =============================================================================

# --- Chat LLM -----------------------------------------------------------------
# Chat Completions API — works with any OpenAI-compatible provider (OpenAI,
# OpenRouter, Together, …). Leave AI_CHAT_API_KEY blank for offline mode.
AI_CHAT_API_KEY=              # chat completion key
AI_CHAT_BASE_URL=             # optional OpenAI-compatible base URL
AI_MODEL=gpt-4o-mini          # chat model id (provider-prefixed on OpenRouter)
AI_PROVIDER=openai            # informational only; NOT read by the code

# --- Embeddings ---------------------------------------------------------------
# Presence of EMBEDDINGS_API_KEY switches retrieval to REAL embeddings at build.
# For OpenRouter you MUST also set EMBEDDINGS_BASE_URL, otherwise the key is sent
# to api.openai.com and 401s. If real embeddings fail at build, the embed step
# falls back to the lexical embedder (the deploy still succeeds).
EMBEDDINGS_API_KEY=           # blank = lexical embedder
EMBEDDINGS_BASE_URL=          # REQUIRED when the key is an OpenRouter key

# --- Example: one OpenRouter key for BOTH chat + embeddings (verified working)-
# AI_CHAT_API_KEY=sk-or-v1-xxxxxxxx
# AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openai/gpt-4o-mini
# EMBEDDINGS_API_KEY=sk-or-v1-xxxxxxxx          # same key
# EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1

# --- Retrieval tuning (optional) ----------------------------------------------
# Cosine cutoff for answer-vs-escalate. Leave UNSET to use the mode-aware default
# (real 0.35 / lexical+chat 0.05 / lexical-offline 0.20).
# RETRIEVAL_THRESHOLD=

# --- Tier 1 only (Upstash Redis) — NOT used by the current code ---------------
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
