# =============================================================================
# Cadre AI Support Chatbot — environment
# Copy to .env.local and fill in. NEVER commit real keys (.env.local is ignored).
#
# The app runs fully OFFLINE with NO keys: a deterministic lexical embedder backs
# retrieval and the chat route returns grounded/escalation responses from the KB.
# Providing keys upgrades to real OpenAI-compatible embeddings + a streamed LLM
# answer. See README / DECISIONS for the offline-vs-online modes.
# =============================================================================

# --- Chat LLM (provider-agnostic via the AI SDK; OpenAI-compatible) ----------
# Leave AI_CHAT_API_KEY blank to run in offline retrieval-only mode.
# Uses the Chat Completions API (works with OpenAI, OpenRouter, Together, etc.).
#
# OpenAI:      AI_MODEL=gpt-4o-mini            AI_CHAT_BASE_URL=            (blank)
# OpenRouter:  AI_MODEL=openai/gpt-4o-mini     AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
AI_PROVIDER=openai              # informational; the adapter uses an OpenAI-compatible client
AI_MODEL=gpt-4o-mini           # chat model id (provider-prefixed for OpenRouter)
AI_CHAT_API_KEY=               # chat completion key
AI_CHAT_BASE_URL=              # optional: OpenAI-compatible base URL (e.g. https://openrouter.ai/api/v1)

# --- Embeddings (OpenAI-compatible; MAY differ from the chat provider) --------
# Leave EMBEDDINGS_API_KEY blank to use the offline deterministic lexical embedder.
EMBEDDINGS_API_KEY=            # OpenAI-compatible key for text-embedding-3-small
EMBEDDINGS_BASE_URL=          # optional: OpenAI-compatible base URL

# --- Retrieval tuning --------------------------------------------------------
# Cosine cutoff below which retrieval is "too weak to ground" -> escalate.
# LEAVE THIS UNSET to use the mode-aware default (0.35 with real embeddings,
# 0.08 with the offline lexical embedder). Setting it to 0.35 while running
# OFFLINE would wrongly escalate valid questions, so only set it when you have
# real embeddings and want to override the default.
# RETRIEVAL_THRESHOLD=0.35

# --- Tier 1 ONLY (Upstash Redis; leave blank for Tier 0) ---------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
