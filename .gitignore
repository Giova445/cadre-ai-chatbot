# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem
*.tsbuildinfo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files — never commit real keys (.env.example IS committed)
.env
.env*.local
.env.development
.env.production

# vercel
.vercel

# ruflo / swarm local state (not part of the app)
/.swarm/
/.claude/
/.claude-flow/
ruvector.db
agentdb.rvf
agentdb.rvf.lock

# installed agent skills (local dev tooling; reproducible via `npx skills add`)
/.agents/
skills-lock.json

# seed output (generated by scripts/gen-seed-sql.ts)
/seed-out/

# built widget bundle (regenerated by prebuild → build:widget)
/public/widget.js

# graphify working directory (regenerable — graphify-out/graph.html and
# GRAPH_REPORT.md are copied into public/ and docs/ as the tracked deliverable;
# regenerate via: graphify update . && graphify label .)
/graphify-out/
